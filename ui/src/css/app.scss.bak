// app global css in SCSS form

// =============================================
// GLOBALNE KOREKTY QUASAR KOMPONENTÓW
// =============================================

.q-field--outlined .q-field__control {
  border-radius: 8px;
}

.q-field--outlined:not(.q-field--focused):not(.q-field--error) {
  .q-field__control::before {
    border-color: rgba(0, 0, 0, 0.2);
  }
}
.body--dark .q-field--outlined:not(.q-field--focused):not(.q-field--error) {
  .q-field__control::before {
    border-color: rgba(255, 255, 255, 0.22);
  }
}

// =============================================
// GLOBALNE STYLE KART I LIST (ZGODNE Z CALCULATORLIST)
// =============================================

.section-label {
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--q-primary);
  border-left: 3px solid var(--q-primary);
  padding-left: 10px;
  margin-bottom: 16px;
}

.hover-primary {
  transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
  &:hover {
    border-color: var(--q-primary);
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08) !important;
  }
}

.body--dark .hover-primary:hover {
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4) !important;
  background-color: rgba(var(--q-primary-rgb), 0.03);
}

.icon-bg {
  background-color: rgba(var(--q-primary-rgb), 0.05);
  padding: 12px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.description-text {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  height: 2.8em;
  line-height: 1.4;
}

// =============================================
// POLA NUMERYCZNE Z JEDNOSTKAMI
// =============================================

.eng-value {
  font-family: 'Roboto Mono', 'Courier New', monospace !important;
  font-weight: 500;
  font-size: 0.95rem;
}

.eng-unit {
  font-family: 'Roboto Mono', monospace;
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  color: $primary;
  opacity: 0.8;
  padding: 0 10px 0 12px;
  border-left: 1px solid rgba(0, 0, 0, 0.15);
  white-space: nowrap;
  align-self: center;
  height: 100%;
  display: flex;
  align-items: center;
}
.body--dark .eng-unit {
  border-left-color: rgba(255, 255, 255, 0.18);
}

.eng-unit-btn {
  font-family: 'Roboto Mono', monospace !important;
  font-size: 0.8rem !important;
  font-weight: 700;
  letter-spacing: 0.05em;
  color: $primary !important;
  border-left: 1px solid rgba(0, 0, 0, 0.15);
  border-radius: 0 !important;
  padding: 0 8px !important;

  .q-icon { font-size: 15px; opacity: 0.5; }
  .q-btn__content { gap: 3px; }
}
.body--dark .eng-unit-btn {
  border-left-color: rgba(255, 255, 255, 0.18);
}

// =============================================
// RADIO FIELD
// =============================================

.calc-radio-field {
  border: 1px solid rgba(0, 0, 0, 0.2);
  border-radius: 8px;
  padding: 12px 16px 10px;
  transition: border-color 0.2s;

  &:hover { border-color: rgba(0, 0, 0, 0.4); }
}
.body--dark .calc-radio-field {
  border-color: rgba(255, 255, 255, 0.22);
  &:hover { border-color: rgba(255, 255, 255, 0.4); }
}

.calc-radio-label {
  font-size: 0.75rem;
  color: rgba(0, 0, 0, 0.6);
  font-weight: 500;
  line-height: 1;
  margin-bottom: 8px;
}
.body--dark .calc-radio-label {
  color: rgba(255, 255, 255, 0.6);
}

// =============================================
// ENGINEERING CALCULATOR UI
// =============================================

.calc-page-header {
  position: relative;
  padding-left: 16px;

  &::before {
    content: '';
    position: absolute;
    left: 0; top: 2px; bottom: 2px;
    width: 4px;
    background: $primary;
    border-radius: 2px;
  }
}

.calc-utb-tag {
  display: inline-block;
  background: $primary;
  color: #fff;
  font-size: 0.6rem;
  font-weight: 800;
  letter-spacing: 0.18em;
  padding: 2px 7px;
  border-radius: 3px;
  vertical-align: middle;
  margin-right: 8px;
  margin-bottom: 3px;
}

.calc-section-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 9px 16px;
  background: rgba($primary, 0.06);
  border-bottom: 1px solid rgba($primary, 0.15);
  color: $primary;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  user-select: none;
}
.body--dark .calc-section-bar {
  background: rgba($primary, 0.18);
  border-bottom-color: rgba($primary, 0.3);
}

.calc-form-actions {
  border-top: 1px solid rgba(0, 0, 0, 0.08);
  padding-top: 16px;
}
.body--dark .calc-form-actions {
  border-top-color: rgba(255, 255, 255, 0.08);
}

// =============================================
// KPI — główny wskaźnik resursu
// =============================================

.kpi-block {
  display: flex;
  align-items: center;
  gap: 28px;
  padding: 20px 24px;
  border-radius: 8px;
  border-left: 5px solid transparent;
  margin-bottom: 24px;
}

.kpi-block-ok     { background: #f1f8e9; border-color: #2e7d32; }
.kpi-block-warn   { background: #fff3e0; border-color: #e65100; }
.kpi-block-danger { background: #fce4ec; border-color: #c62828; }

.body--dark .kpi-block-ok     { background: rgba(46, 125, 50, 0.12);  border-color: #66bb6a; }
.body--dark .kpi-block-warn   { background: rgba(230, 81, 0, 0.12);   border-color: #ffa726; }
.body--dark .kpi-block-danger { background: rgba(198, 40, 40, 0.12);  border-color: #ef5350; }

.kpi-number {
  font-family: 'Roboto Mono', 'Courier New', monospace;
  font-size: 3rem;
  font-weight: 700;
  line-height: 1;
  letter-spacing: -0.02em;
  white-space: nowrap;
}
.kpi-number-ok     { color: #2e7d32; }
.kpi-number-warn   { color: #e65100; }
.kpi-number-danger { color: #c62828; }
.body--dark .kpi-number-ok     { color: #81c784; }
.body--dark .kpi-number-warn   { color: #ffb74d; }
.body--dark .kpi-number-danger { color: #e57373; }

.kpi-label-text {
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  opacity: 0.6;
  margin-bottom: 4px;
}

.kpi-status-pill {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  padding: 2px 10px;
  border-radius: 20px;
  text-transform: uppercase;
  margin-top: 8px;
}
.kpi-pill-ok     { background: #c8e6c9; color: #1b5e20; }
.kpi-pill-warn   { background: #ffe0b2; color: #bf360c; }
.kpi-pill-danger { background: #ffcdd2; color: #b71c1c; }
.body--dark .kpi-pill-ok     { background: rgba(46, 125, 50, 0.35);  color: #a5d6a7; }
.body--dark .kpi-pill-warn   { background: rgba(230, 81, 0, 0.35);   color: #ffcc80; }
.body--dark .kpi-pill-danger { background: rgba(198, 40, 40, 0.35);  color: #ef9a9a; }

// =============================================
// TABELA WYNIKÓW
// =============================================

.result-section-header {
  border-left: 3px solid $primary;
  padding-left: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  font-size: 0.72rem;
  color: $primary;
}

.result-value {
  font-family: 'Roboto Mono', 'Courier New', monospace;
  font-weight: 600;
  font-size: 1.05rem;
}

.eng-result-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 7px 14px;
  border-bottom: 1px solid rgba(0, 0, 0, 0.07);
  &:nth-child(even) { background: rgba(0, 0, 0, 0.018); }
  &:last-child { border-bottom: none; }
}
.body--dark .eng-result-row {
  border-bottom-color: rgba(255, 255, 255, 0.07);
  &:nth-child(even) { background: rgba(255, 255, 255, 0.03); }
}

// =============================================
// PRINT
// =============================================

@media print {
  .no-print { display: none !important; }
  .q-drawer, .q-header { display: none !important; }
  .q-page-container { padding: 0 !important; margin: 0 !important; }
  .print-only { display: block !important; }
}
.print-only { display: none; }
