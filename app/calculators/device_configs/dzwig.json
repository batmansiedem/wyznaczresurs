{
  "name": "Dźwig",
  "description": "Kalkulator resursu dla dźwigu.",
  "fields": {
    "wykonawca": {
      "type": "text",
      "label": "Wykonawca",
      "required": false
    },
    "uwagi": {
      "type": "textarea",
      "label": "Uwagi",
      "required": false
    },
    "nr_fabryczny": {
      "type": "text",
      "label": "Nr fabryczny",
      "required": true
    },
    "nr_ewidencyjny": {
      "type": "text",
      "label": "Nr ewidencyjny UDT/TDT/WDT",
      "required": false
    },
    "rok_budowy": {
      "type": "number",
      "label": "Rok budowy dźwigu",
      "required": true
    },
    "lata_pracy": {
      "type": "number",
      "label": "Ilość przepracowanych lat",
      "required": true,
      "unit_options": [
        "lata",
        "miesiące"
      ],
      "default_unit": "lata"
    },
    "cykle_dzwig": {
      "type": "number",
      "label": "Ilość jazd dźwigu",
      "required": false
    },
    "pyt_motogodzin": {
      "type": "select",
      "label": "Czy dźwig posiada licznik motogodzin?",
      "required": true,
      "options": [
        {
          "label": "Tak",
          "value": "1"
        },
        {
          "label": "Nie",
          "value": "0"
        }
      ]
    },
    "licznik_pracy": {
      "type": "number",
      "label": "Łączna ilość motogodzin",
      "required": false,
      "show_if": {
        "field": "pyt_motogodzin",
        "value": "1"
      },
      "default_unit": "mth"
    },
    "dni_robocze": {
      "type": "number",
      "label": "Ilość dni roboczych w roku",
      "required": true
    },
    "zakres_godzin_1": {
      "type": "number",
      "label": "Ilość godz. pracy dźwigu w przedziale 5:00–9:00",
      "required": false,
      "show_if": {
        "field": "pyt_motogodzin",
        "value": "0"
      }
    },
    "zakres_godzin_2": {
      "type": "number",
      "label": "Ilość godz. pracy dźwigu w przedziale 9:00–13:00",
      "required": false,
      "show_if": {
        "field": "pyt_motogodzin",
        "value": "0"
      }
    },
    "zakres_godzin_3": {
      "type": "number",
      "label": "Ilość godz. pracy dźwigu w przedziale 13:00–17:00",
      "required": false,
      "show_if": {
        "field": "pyt_motogodzin",
        "value": "0"
      }
    },
    "zakres_godzin_4": {
      "type": "number",
      "label": "Ilość godz. pracy dźwigu w przedziale 17:00–21:00",
      "required": false,
      "show_if": {
        "field": "pyt_motogodzin",
        "value": "0"
      }
