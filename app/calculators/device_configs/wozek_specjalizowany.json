{
  "name": "Wózek specjalizowany",
  "description": "Kalkulator resursu dla wózka specjalizowanego.",
  "fields": {
    "wykonawca": {
      "type": "text",
      "label": "Wykonawca",
      "required": false
    },
    "uwagi": {
      "type": "textarea",
      "label": "Uwagi",
      "required": false
    },
    "typ": {
      "type": "select",
      "label": "Typ wózka specjalizowanego",
      "required": false,
      "options": [
        "Wózek specjalizowany z masztem",
        "Wózek specjalizowany z żurawiem",
        "Wózek specjalizowany boczny"
      ]
    },
    "nr_fabryczny": {
      "type": "text",
      "label": "Nr fabryczny",
      "required": true
    },
    "nr_ewidencyjny": {
      "type": "text",
      "label": "Nr ewidencyjny UDT/TDT/WDT",
      "required": false
    },
    "q_max": {
      "type": "number",
      "label": "Udźwig maksymalny Q<sub>max</sub> [kg]",
      "required": true,
      "unit_type": "mass",
      "default_unit": "kg",
      "unit_options": [
        "kg",
        "t"
      ]
    },
    "q_o": {
      "type": "number",
      "label": "Masa osprzętu Q<sub>o</sub> [kg]",
      "required": false,
      "unit_type": "mass",
      "default_unit": "kg",
      "unit_options": [
        "kg",
        "t"
      ]
    },
    "h_max": {
      "type": "number",
      "label": "Maksymalna wysokość podnoszenia [m]",
      "required": true,
      "unit_type": "length",
      "default_unit": "m"
    },
    "L_b_max": {
      "type": "number",
      "label": "Maksymalny wysięg boczny [m]",
      "required": true,
      "unit_type": "length",
      "default_unit": "m"
    },
    "v_pod": {
      "type": "number",
      "label": "Prędkość podnoszenia/opuszczania [m/min]",
      "required": false,
      "unit_type": "velocity",
      "default_unit": "m/min"
    },
    "sposob_pracy": {
      "type": "select",
      "label": "Sposób pracy wózka specjalizowanego",
      "required": true,
      "options": [
        "wózek widłowy/ładowarka",
        "podnośnik koszowy/wózek widłowy/ładowarka"
      ]
    },
    "operator": {
      "type": "select",
      "label": "Ilość operatorów",
      "required": true,
      "options": [
        "1 operator",
        "2 operatorów",
        "3 operatorów",
        "4 operatorów",
        "5 i więcej operatorów"
      ]
    },
    "lata_pracy": {
      "type": "number",
      "label": "Ilość przepracowanych lat",
      "required": true,
      "unit_type": "time",
      "default_unit": "lata",
      "unit_options": [
        "lata",
        "miesiące"
      ]
    },
    "ilosc_moto": {
      "type": "number",
      "label": "Ilość motogodzin od początku eksploatacji",
      "required": true,
      "show_if": {
        "field": "sposob_pracy",
        "value": "wózek widłowy/ładowarka"
      }
    },
    "procent_jazda": {
      "type": "number",
      "label": "Procent motogodzin przypadających na jazdę [%]",
      "required": true,
      "show_if": {
        "field": "sposob_pracy",
        "value": "wózek widłowy/ładowarka"
      }
    },
    "max_moto_prod": {
      "type": "number",
      "label": "Graniczna ilość motogodzin określona przez producenta",
      "required": false,
      "default_value": 15000,
      "show_if": {
        "field": "sposob_pracy",
        "value": "wózek widłowy/ładowarka"
      }
    },
    "ilosc_cykli": {
      "type": "number",
      "label": "Ilość odbytych cykli",
      "required": true,
      "unit_type": "dimensionless",
      "default_unit": "cykl"
    },
    "procent_podnosnik": {
      "type": "number",
      "label": "Procent motogodzin przypadających na pracę jako podnośnik koszowy [%]",
      "required": true,
      "show_if": {
        "field": "sposob_pracy",
        "value": "podnośnik koszowy/wózek widłowy/ładowarka"
      }
    },
    "tryb_pracy": {
      "label": "Tryb pracy",
      "type": "select",
      "required": true,
      "options": [
        "jednozmianowy",
        "dwuzmianowy",
        "trzyzmianowy"
      ]
    },
    "cykle_zmiana": {
      "label": "Ilość cykli przypadających na zmianę",
      "type": "number",
      "required": true
    },
    "dni_robocze": {
      "label": "Ilość dni roboczych w roku",
      "type": "number",
      "required": true,
      "default_value": 250
    },
    "sposob_rejestracji": {
      "type": "select",
      "label": "Sposób rejestracji warunków eksploatacji",
      "required": true,
      "options": [
        "Rejestrowanie przyrządami",
        "Rejestrowanie w dzienniku, łącznie ze stosowaniem licznika",
        "Rejestrowanie na podstawie procesu technologicznego",
        "Rejestrowanie na podstawie informacji o produkcji",
        "Informacja o warunkach eksploatacji jest niekompletna",
        "Brak informacji o historii urządzenia"
      ]
    },
    "spec": {
      "type": "select",
      "label": "Czy chcesz wyznaczyć resurs po pierwszym przeglądzie specjalnym?",
      "required": true,
      "options": [
        "Nie",
        "Tak"
      ]
    },
    "ponowny_resurs": {
      "type": "select",
      "label": "Czy chcesz wykonać ponowne wyznaczenie resursu?",
      "required": true,
      "options": [
        "Nie",
        "Tak"
      ]
    },
    "ostatni_resurs": {
      "type": "number",
      "label": "Procent wykorzystania resursu z ostatnich obliczeń",
      "required": false,
      "show_if": {
        "field": "ponowny_resurs",
        "value": "Tak"
      },
      "default_unit": "%"
    },
    "data_resurs": {
      "type": "date",
      "label": "Data wyznaczenia ostatniego resursu",
      "required": false,
      "show_if": {
        "field": "ponowny_resurs",
        "value": "Tak"
      }
    },
    "konstrukcja": {
      "type": "inspection_status",
      "label": "Czy konstrukcja stalowa jest zdeformowana i/lub pojawiły się pęknięcia w złączach spawanych?",
      "required": true,
      "options": [
        "Brak uszkodzeń",
        "Uszkodzenia"
      ]
    },
    "automatyka": {
      "type": "inspection_status",
      "label": "Czy automatyka sterująca i/lub zabezpieczająca jest sprawna i aktywna?",
      "required": true,
      "options": [
        "Sprawna",
        "Niesprawna"
      ]
    },
    "sworznie": {
      "type": "inspection_status",
      "label": "Czy sworznie oraz połączenia rozłączne są właściwie zmontowane i w dobrym stanie technicznym?",
      "required": true,
      "options": [
        "Prawidłowy",
        "Nieprawidłowy"
      ]
    },
    "ciegna": {
      "type": "inspection_status",
      "label": "Czy cięgna (łańcuchy, liny) są w dobrym stanie technicznym?",
      "required": true,
      "options": [
        "Brak uszkodzeń",
        "Uszkodzenia"
      ]
    },
    "eksploatacja": {
      "type": "inspection_status",
      "label": "Czy urządzenie eksploatowane jest zgodnie z przeznaczeniem i instrukcją eksploatacji?",
      "required": true,
      "options": [
        "Zgodne",
        "Niezgodne"
      ]
    },
    "szczelnosc": {
      "type": "inspection_status",
      "label": "Czy układ hydrauliczny jest szczelny, a zawory zwrotne sprawne?",
      "required": true,
      "options": [
        "Tak",
        "Nie",
        "N/D"
      ]
    },
    "diagram_kd": {
      "type": "diagram",
      "label": "Widmo obciążeń K<sub>d</sub>",
      "svg": "schemat_kd"
    }
  },
  "sections": [
    {
      "id": "informacje",
      "title": "Informacja na temat resursu",
      "icon": "info",
      "fields": [
        "spec",
        "ponowny_resurs",
        "data_resurs",
        "ostatni_resurs"
      ]
    },
    {
      "id": "dane",
      "title": "Dane urządzenia",
      "icon": "settings",
      "fields": [
        "wykonawca",
        "uwagi",
        "typ",
        "nr_fabryczny",
        "nr_ewidencyjny",
        "q_max",
        "q_o",
        "h_max",
        "L_b_max",
        "v_pod"
      ]
    },
    {
      "id": "praca",
      "title": "Warunki pracy",
      "icon": "engineering",
      "fields": [
        "sposob_pracy",
        "operator",
        "lata_pracy"
      ]
    },
    {
      "id": "uzytkowanie",
      "title": "Intensywność użytkowania",
      "icon": "history",
      "fields": [
        "ilosc_moto",
        "procent_jazda",
        "max_moto_prod",
        "ilosc_cykli",
        "procent_podnosnik",
        "tryb_pracy",
        "cykle_zmiana",
        "dni_robocze"
      ]
    },
    {
      "id": "rejestracja",
      "title": "Rejestracja warunków",
      "icon": "assignment",
      "fields": [
        "sposob_rejestracji"
      ]
    },
    {
      "id": "kd",
      "title": "Współczynnik K<sub>d</sub>",
      "icon": "balance",
      "fields": [
        "diagram_kd"
      ]
    },
    {
      "id": "inspekcja",
      "title": "Ocena stanu technicznego",
      "icon": "fact_check",
      "fields": [
        "konstrukcja",
        "automatyka",
        "sworznie",
        "ciegna",
        "eksploatacja",
        "szczelnosc"
      ]
    }
  ],
  "output_fields": {
    "resurs_wykorzystanie": {
      "label": "Wykorzystanie resursu",
      "type": "percentage",
      "unit": "%"
    },
    "resurs_message": {
      "label": "Status resursu",
      "type": "text"
    },
    "data_prognoza": {
      "label": "Prognozowana data",
      "type": "date"
    },
    "wsp_kdr": {
      "label": "Współczynnik K<sub>d</sub>",
      "type": "number"
    },
    "stan_obciazenia": {
      "label": "Stan obciążenia",
      "type": "text"
    },
    "T_WSK": {
      "label": "Projektowa żywotność T<sub>WSK</sub>",
      "type": "number",
      "unit": "mth"
    },
    "U_WSK": {
      "label": "Projektowa żywotność U<sub>WSK</sub>",
      "type": "number",
      "unit": "cykle"
    },
    "ilosc_moto_cal": {
      "label": "Zredukowana ilość motogodzin",
      "type": "number",
      "unit": "mth"
    },
    "ilosc_cykli_rok": {
      "label": "Ilość cykli na rok",
      "type": "number",
      "unit": "cykle/rok"
    },
    "moto_rok": {
      "label": "Ilość motogodzin na rok",
      "type": "number",
      "unit": "mth/rok"
    }
  }
}
