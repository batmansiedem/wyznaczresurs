{
  "name": "Wózek specjalizowany",
  "description": "Kalkulator resursu dla wózka specjalizowanego.",
  "fields": {
    "wykonawca": {
      "type": "text",
      "label": "Wykonawca",
      "required": true
    },
    "uwagi": {
      "type": "textarea",
      "label": "Uwagi",
      "required": false
    },
    "typ": {
      "type": "select",
      "label": "Typ wózka specjalizowanego",
      "required": false,
      "options": [
        "Wózek specjalizowany z masztem",
        "Wózek specjalizowany z żurawiem",
        "Wózek specjalizowany boczny"
      ]
    },
    "nr_fabryczny": {
      "type": "text",
      "label": "Nr fabryczny wózka specjalizowanego",
      "required": true
    },
    "nr_ewidencyjny": {
      "type": "text",
      "label": "Nr ewidencyjny UDT/TDT/WDT",
      "required": false
    },
    "sposob_pracy": {
      "type": "select",
      "label": "Sposób pracy wózka specjalizowanego",
      "required": true,
      "options": [
        "wózek widłowy/ładowarka",
        "podnośnik koszowy/wózek widłowy/ładowarka"
      ]
    },
    "procent_jazda": {
      "type": "number",
      "label": "Określ procent motogodzin przypadających na jazdę [%]",
      "required": true,
      "show_if": {
        "field": "sposob_pracy",
        "value": "wózek widłowy/ładowarka"
      }
    },
    "procent_podnosnik": {
      "type": "number",
      "label": "Określ procent motogodzin przypadających na pracę jako podnośnik koszowy [%]",
      "required": true,
      "show_if": {
        "field": "sposob_pracy",
        "value": "podnośnik koszowy/wózek widłowy/ładowarka"
      }
    },
    "operator": {
      "type": "select",
      "label": "Ilość operatorów",
      "required": true,
      "options": [
        "1 operator",
        "2 operatorów",
        "3 operatorów",
        "4 operatorów",
        "5 i więcej operatorów"
      ]
    },
    "h_max": {
      "type": "number",
      "label": "Maksymalna wysokość podnoszenia h<sub>max</sub> [m]",
      "required": true,
      "unit_type": "length",
      "default_unit": "m"
    },
    "L_b_max": {
      "type": "number",
      "label": "Maksymalny wysięg boczny L<sub>b,max</sub> [m]",
      "required": true,
      "unit_type": "length",
      "default_unit": "m"
    },
    "v_pod": {
      "type": "number",
      "label": "Prędkość podnoszenia/opuszczania v<sub>pod</sub> [m/min]",
      "required": false,
      "unit_type": "velocity",
      "default_unit": "m/min"
    },
    "q_max": {
      "type": "number",
      "label": "Udźwig maksymalny wózka specjalizowanego Q<sub>max</sub> [kg]",
      "required": true,
      "unit_type": "mass",
      "default_unit": "kg",
      "unit_options": [
        "kg",
        "t"
      ]
    },
    "q_o": {
      "type": "number",
      "label": "Masa osprzętu Q<sub>osp</sub> [kg]",
      "required": false,
      "unit_type": "mass",
      "default_unit": "kg",
      "unit_options": [
        "kg",
        "t"
      ]
    },
    "lata_pracy": {
      "type": "number",
      "label": "Ilość przepracowanych lat od ostatniego przeglądu specjalnego lub rozp. eksploatacji",
      "required": true,
      "unit_type": "time",
      "default_unit": "lata",
      "unit_options": [
        "lata",
        "miesiące"
      ]
    },
    "max_moto_prod": {
      "type": "number",
      "label": "Graniczna ilość motogodzin określona przez producenta [mth]",
      "required": false
    },
    "ilosc_moto": {
      "type": "number",
      "label": "Ilość odbytych motogodzin od ostatniego przeglądu specjalnego lub rozp. eksploatacji [mth]",
      "required": true
    },
    "ilosc_cykli": {
      "type": "number",
      "label": "Ilość odbytych cykli od ostatniego przeglądu specjalnego lub rozp. eksploatacji",
      "required": true,
      "unit_type": "dimensionless",
      "default_unit": "cykl"
    },
    "cykle_zmiana": {
      "label": "Ilość cykli przypadających na zmianę",
      "type": "number",
      "required": false
    },
    "dni_robocze": {
      "label": "Ilość dni roboczych w roku",
      "type": "number",
      "required": false,
      "default_value": 250
    },
    "tryb_pracy": {
      "label": "Tryb pracy",
      "type": "select",
      "required": false,
      "options": [
        "jednozmianowy",
        "dwuzmianowy",
        "trzyzmianowy"
      ]
    },
    "sposob_rejestracji": {
      "type": "select",
      "label": "Określ sposób rejestracji warunków eksploatacji",
      "required": true,
      "options": [
        "Rejestrowanie przyrządami",
        "Rejestrowanie w dzienniku, łącznie ze stosowaniem licznika",
        "Rejestrowanie na podstawie procesu technologicznego",
        "Rejestrowanie na podstawie informacji o produkcji",
        "Informacja o warunkach eksploatacji jest niekompletna",
        "Brak informacji o historii urządzenia"
      ]
    },
    "konstrukcja": {
      "type": "inspection_status",
      "label": "Czy konstrukcja stalowa jest w dobrym stanie (brak deformacji i pęknięć w złączach spawanych)?",
      "required": true,
      "options": [
        "Tak",
        "Nie"
      ]
    },
    "automatyka": {
      "type": "inspection_status",
      "label": "Czy automatyka sterująca i/lub zabezpieczająca jest sprawna i aktywna?",
      "required": true,
      "options": [
        "Tak",
        "Nie",
        "N/D"
      ]
    },
    "sworznie": {
      "type": "inspection_status",
      "label": "Czy sworznie oraz połączenia rozłączne są właściwie zmontowane oraz w dobrym stanie technicznym?",
      "required": true,
      "options": [
        "Tak",
        "Nie"
      ]
    },
    "eksploatacja": {
      "type": "inspection_status",
      "label": "Czy urządzenie eksploatowane jest zgodnie z przeznaczeniem i instrukcją eksploatacji?",
      "required": true,
      "options": [
        "Tak",
        "Nie"
      ]
    },
    "szczelnosc": {
      "type": "inspection_status",
      "label": "Czy układ hydrauliczny jest szczelny, a zawory zwrotne sprawne?",
      "required": true,
      "options": [
        "Tak",
        "Nie",
        "N/D"
      ]
    },
    "diagram_kd": {
      "type": "diagram",
      "label": "Widmo obciążeń K<sub>d</sub>",
      "svg": "schemat_kd"
    },
    "diagram_ldr": {
      "type": "diagram",
      "label": "Współczynnik wykorzystania dł. wysięgu bocznego i wys. podnoszenia L<sub>dr</sub>",
      "svg": "schemat_ldr"
    }
  },
  "sections": [
    {
      "id": "dane",
      "title": "Określ dane dla wózka specjalizowanego",
      "icon": "settings",
      "fields": [
        "wykonawca",
        "uwagi",
        "typ",
        "nr_fabryczny",
        "sposob_pracy",
        "procent_jazda",
        "procent_podnosnik",
        "operator",
        "h_max",
        "L_b_max",
        "v_pod",
        "q_max",
        "q_o",
        "lata_pracy",
        "max_moto_prod",
        "ilosc_moto",
        "ilosc_cykli",
        "cykle_zmiana",
        "dni_robocze",
        "tryb_pracy"
      ]
    },
    {
      "id": "rejestracja",
      "title": "Określ sposób rejestracji",
      "icon": "assignment",
      "fields": [
        "sposob_rejestracji"
      ]
    },
    {
      "id": "kd",
      "title": "Współczynniki obciążenia i geometrii",
      "icon": "balance",
      "fields": [
        "diagram_kd",
        "diagram_ldr"
      ]
    },
    {
      "id": "inspekcja_konstr",
      "title": "Wizualnie oceń stan konstrukcji nośnej",
      "icon": "architecture",
      "fields": [
        "konstrukcja"
      ]
    },
    {
      "id": "inspekcja_auto",
      "title": "Automatyka sterująca i zabezpieczająca",
      "icon": "auto_mode",
      "fields": [
        "automatyka"
      ]
    },
    {
      "id": "inspekcja_sworz",
      "title": "Wizualnie oceń stan połączeń ruchowych i rozłącznych",
      "icon": "construction",
      "fields": [
        "sworznie"
      ]
    },
    {
      "id": "inspekcja_ekspl",
      "title": "Eksploatacja",
      "icon": "engineering",
      "fields": [
        "eksploatacja"
      ]
    },
    {
      "id": "inspekcja_szczel",
      "title": "Szczelność układu hydraulicznego",
      "icon": "water_drop",
      "fields": [
        "szczelnosc"
      ]
    }
  ],
  "output_fields": {
    "resurs_wykorzystanie": {
      "label": "Resurs wykorzystanie",
      "type": "percentage",
      "unit": "%"
    },
    "resurs_message": {
      "label": "Zalecenia",
      "type": "text"
    },
    "data_prognoza": {
      "label": "Symulowana data osiągnięcia resursu *",
      "type": "date"
    },
    "wsp_kdr": {
      "label": "Współczynnik K<sub>d</sub>",
      "type": "number"
    },
    "stan_obciazenia": {
      "label": "Stan obciążenia wózka specjalizowanego",
      "type": "text"
    },
    "T_WSK": {
      "label": "Maksymalna liczba motogodzin T<sub>WSK</sub>",
      "type": "number",
      "unit": "mth"
    },
    "U_WSK": {
      "label": "Maksymalna liczba cykli U<sub>WSK</sub>",
      "type": "number",
      "unit": "cykle"
    },
    "ldr": {
      "label": "Współczynnik wykorzystania dł. wysięgu bocznego i wys. podnoszenia L<sub>dr</sub>",
      "type": "number",
      "unit": "[-]"
    },
    "F_X": {
      "label": "Współczynnik F",
      "type": "number",
      "unit": "[-]"
    },
    "ilosc_moto_cal": {
      "label": "Zredukowana ilość motogodzin",
      "type": "number",
      "unit": "mth"
    },
    "ilosc_cykli_rok": {
      "label": "ilość cykli przypadających na rok",
      "type": "number",
      "unit": "cykle/rok"
    },
    "moto_rok": {
      "label": "ilość motogodzin przypadających na rok",
      "type": "number",
      "unit": "mth/rok"
    }
  }
}
